# Dashboard runtime
NODE_ENV=production

# Dashboard read DB connection
COLLECTOR_DB_URL=postgres://displayer_user:password@timescaledb:5432/graphql_analytics?sslmode=disable

# Path to GraphQL schema SDL (inside container or local filesystem)
SCHEMA_SDL_PATH=/schema/schema.graphql

# Collector health endpoint used by dashboard service checks
COLLECTOR_HEALTH_URL=http://collector:4318/health

